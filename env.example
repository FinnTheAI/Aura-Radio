# Server
PORT=8080
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173

# Paths (repo-relative if not absolute)
DATA_DIR=./data
USER_DATA_DIR=./data/user
PROMPTS_DIR=./prompts
STATE_DB_PATH=./data/state.db

# NeteaseCloudMusicApi base (local or hosted). Empty + NCM_MOCK=1 uses yt-dlp fallback.
# 本机示例：先启动 NeteaseCloudMusicApi（默认常听端口 3000），再设：
#   NCM_API_BASE_URL=http://127.0.0.1:3000
#   NCM_MOCK=0
# 若 NCM_API_BASE_URL 为空且 NCM_MOCK=1，系统会调用 yt-dlp 从网易云音乐官网抓取播放 URL。
# 提示：需本地安装 yt-dlp (https://github.com/yt-dlp/yt-dlp)
# NCM_FETCH_TIMEOUT_MS=20000
# 若上游代理要求登录态，仅在本地 .env 设置（勿提交仓库）：
# NCM_UPSTREAM_COOKIE=
NCM_API_BASE_URL=
NCM_MOCK=1

# MiniMax — MOCK=1：离线 DJ JSON + 队列内占位音频 URL（见 MINIMAX_MOCK_VOICE_URL）
# 真实调用：MINIMAX_MOCK=0 + MINIMAX_API_KEY；API 基座可省略，默认 https://api.minimax.io/v1
MINIMAX_API_URL=https://api.minimax.io/v1
MINIMAX_API_KEY=
MINIMAX_MODEL=MiniMax-M2.7
MINIMAX_FETCH_TIMEOUT_MS=60000
MINIMAX_MOCK=1
MINIMAX_MOCK_VOICE_URL=

# Dev / test
LOG_LEVEL=info
