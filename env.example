# Server
PORT=8080
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173

# Paths (repo-relative if not absolute)
DATA_DIR=./data
USER_DATA_DIR=./data/user
PROMPTS_DIR=./prompts
STATE_DB_PATH=./data/state.db

# NeteaseCloudMusicApi base (local or hosted).
# 本机示例：先启动 NeteaseCloudMusicApi（默认常听端口 3000），再设：
#   NCM_API_BASE_URL=http://127.0.0.1:3000
#   NCM_MOCK=0
# NCM_MOCK=1 且无 API 地址时：默认直接使用占位 MP3（快），不再调用 yt-dlp。
# 若仍想用 yt-dlp 实验性解析真实外链：NCM_MOCK_USE_YTDLP=1（可能受地理限制、较慢）。
# 提示：yt-dlp 安装见 https://github.com/yt-dlp/yt-dlp
# NCM_FETCH_TIMEOUT_MS=20000
# 若上游代理要求登录态，仅在本地 .env 设置（勿提交仓库）：
# NCM_UPSTREAM_COOKIE=
NCM_API_BASE_URL=
NCM_MOCK=1

# 点播意图：`/api/chat` 里「播放xxx」→ **ncmSearch**（需上方 NCM_API_BASE_URL + NCM_MOCK=0）。
# 必须显式开启，否则永远走 MiniMax brain（容易误以为「搜歌坏了」）。
NETEASE_CLI_ENABLED=0

# Brain / DJ 话术 — Claude Code 架构 + MiniMax 实现
# 架构层：Claude Code（意图分流 → Context Builder → 大脑适配器）
# 实现层：Executor 通过适配器调用 MiniMax
# 真实调用：MINIMAX_MOCK=0 + MINIMAX_API_KEY
# MOCK=1：离线 DJ JSON（兜底）
MINIMAX_API_URL=https://api.minimax.chat/v1
MINIMAX_API_KEY=
MINIMAX_MODEL=MiniMax-M2.7
MINIMAX_FETCH_TIMEOUT_MS=60000
MINIMAX_MOCK=1
MINIMAX_MOCK_VOICE_URL=

# 预留：未来切 Claude API 时启用
# CLAUDE_API_URL=https://api.anthropic.com/v1
# CLAUDE_API_KEY=
# CLAUDE_MODEL=claude-sonnet-4.6

# Dev / test
LOG_LEVEL=info
