# Server
PORT=8080
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173

# Paths (repo-relative if not absolute)
DATA_DIR=./data
USER_DATA_DIR=./data/user
PROMPTS_DIR=./prompts
STATE_DB_PATH=./data/state.db

# Netease Cloud Music HTTP 上游（Enhanced / 代理）。写进 .env **一次即可**，不必每次重装项目重写。
#
# MiniMax-first：用户通过 Brain 的对话决定 `play[]`；`/api/chat` 默认不重写为「点播抢答」（见下方 NETEASE_CLI_ENABLED）。
#
# 方式 A — 手写地址：
# NCM_API_BASE_URL=http://127.0.0.1:3000
#
# 方式 B — `NCM_API_BASE_URL` 留空但本机端口固定：`NCM_ALLOW_LOCAL_DEFAULT=1` → 自动用 http://127.0.0.1:3000（或 NCM_LOCAL_FALLBACK_PORT）
# NCM_ALLOW_LOCAL_DEFAULT=0
# NCM_LOCAL_FALLBACK_PORT=3000
#
# NCM_MOCK=0 且无可用上游时仍可配合 NCM_MOCK_USE_YTDLP / 占位音频；勿提交 Cookie。
NCM_API_BASE_URL=
NCM_ALLOW_LOCAL_DEFAULT=0
NCM_LOCAL_FALLBACK_PORT=3000
NCM_MOCK=1
# NCM_MOCK=1 且无解析后上游时：占位 MP3；试真实外链：NCM_MOCK_USE_YTDLP=1（慢 / 地理敏感）
# NCM_MOCK_USE_YTDLP=1
# NCM_FETCH_TIMEOUT_MS=20000
# 代理登录态仅在本地填写：NCM_UPSTREAM_COOKIE=
# 或单独写 MUSIC_U（与 NCM_UPSTREAM_COOKIE 会自动合并发往代理，勿提交）
# MUSIC_U=
# 若 Cookie 已知 UID 可直接写（否则启动同步时用 /user/account 推断）：NETEASE_UID=

# 点播抢答（默认关，MiniMax-first）：`NETEASE_CLI_ENABLED=1` 时「播放xxx」先入 `ncmSearch`。**产品默认关掉**，让给 MiniMax。
NETEASE_CLI_ENABLED=0

# Brain / DJ 话术 — Claude Code 架构 + MiniMax 实现
# 架构层：Claude Code（意图分流 → Context Builder → 大脑适配器）
# 实现层：Executor 通过适配器调用 MiniMax
# 真实调用：MINIMAX_MOCK=0 + MINIMAX_API_KEY
# MOCK=1：离线 DJ JSON（兜底）
MINIMAX_API_URL=https://api.minimax.chat/v1
MINIMAX_API_KEY=
MINIMAX_MODEL=MiniMax-M2.7
MINIMAX_FETCH_TIMEOUT_MS=60000
MINIMAX_MOCK=1
MINIMAX_MOCK_VOICE_URL=

# 预留：未来切 Claude API 时启用
# CLAUDE_API_URL=https://api.anthropic.com/v1
# CLAUDE_API_KEY=
# CLAUDE_MODEL=claude-sonnet-4.6

# Dev / test
LOG_LEVEL=info
